{
    "app-id": "ar.xjuan.Cambalache",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "separate-locales": false,
    "command": "cambalache",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=home",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "python3-lxml",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --exists-action=i --ignore-installed --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"lxml\" --no-build-isolation"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/80/61/d3dc048cd6c7be6fe45b80cedcbdd4326ba4d550375f266d9f4246d0f4bc/lxml-5.3.2.tar.gz",
                    "sha256": "773947d0ed809ddad824b7b14467e1a481b8976e87278ac4a730c2f7c7fcddc1"
                }
            ]
        },
        {
            "name": "libseat",
            "buildsystem": "meson",
            "config-opts": [
                "-Dserver=disabled",
                "-Dman-pages=disabled"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://git.sr.ht/~kennylevinsen/seatd/archive/0.9.2.tar.gz",
                    "sha256": "2811654fc87b3b1877f62e69cbf1e761c7072146f127860d9b8fe1ca27607d0e",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 234932,
                        "stable-only": true,
                        "url-template": "https://git.sr.ht/~kennylevinsen/seatd/archive/$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "wlroots",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts": [],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.freedesktop.org/wlroots/wlroots.git",
                    "tag": "0.18.1",
                    "commit": "5bc39071d173301eb8b2cd652c711075526dfbd9"
                }
            ]
        },
        {
            "name": "casilda",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts": [],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jpu/casilda.git",
                    "tag": "1.0.0",
                    "commit": "678d21564ab099ea0ccdc95387ae97ed56b97e45"
                }
            ]
        },
        {
            "name": "cambalache",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/jpu/cambalache.git",
                    "tag": "0.99.8",
                    "commit": "946356b4aca8a86070709c29d7a7dce9059a0cdb",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 234786,
                        "stable-only": true,
                        "tag-template": "$version"
                    }
                }
            ]
        }
    ]
}
